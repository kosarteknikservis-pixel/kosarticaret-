APP_NAME=Kosar
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8001

APP_LOCALE=tr
APP_FALLBACK_LOCALE=tr

# Geliştirme: SQLite
DB_CONNECTION=sqlite

# Üretim: MySQL (DB_CONNECTION=mysql yapın)
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=kosar
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
QUEUE_CONNECTION=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="siparis@kosar.com.tr"
MAIL_FROM_NAME="${APP_NAME}"

ADMIN_PASSWORD=kosar-dev

# Kosar marka
KOSAR_NAME=Koşar
KOSAR_EMAIL=info@kosar.com.tr
KOSAR_FREE_SHIPPING=1000
KOSAR_ORDER_PREFIX=KOS

# Ödeme: mock | iyzico | paytr
PAYMENT_PROVIDER=mock
# IYZICO_API_KEY=
# IYZICO_SECRET_KEY=
# IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# PAYTR_MERCHANT_ID=
# PAYTR_MERCHANT_KEY=
# PAYTR_MERCHANT_SALT=
# PAYTR_TEST_MODE=true

FILESYSTEM_DISK=public

# İletişim formu spam koruması (Cloudflare Turnstile — https://dash.cloudflare.com)
# RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=

# Panel site hızı — Google PageSpeed Insights API (tercihen panelden Site ayarları → Entegrasyonlar)
# PAGESPEED_API_KEY=
# PAGESPEED_AUDIT_BASE_URL=https://kosarticaret.com
# PAGESPEED_CACHE_MINUTES=360

# Telegram sipariş bildirimi (tercihen panelden Entegrasyonlar → Bildirimler)
# TELEGRAM_ENABLED=false
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Otomatik index bildirimi — IndexNow panelden açılır; Google Indexing API isteğe bağlı
# GOOGLE_INDEXING_ENABLED=false
# GOOGLE_INDEXING_CREDENTIALS=storage/app/google-indexing-service-account.json
# INDEXING_USE_QUEUE=false
